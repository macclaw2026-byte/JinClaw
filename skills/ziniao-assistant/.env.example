# Ziniao Assistant local configuration
# Fill this file yourself with the real secrets.
# Do not commit real keys.

# Local bridge base URL
ZCLAW_BASE_URL=http://127.0.0.1:9481

# Same meaning as above; keep aligned if your bridge expects this name
ZINIAO_ZCLAW_BASE_URL=http://127.0.0.1:9481

# Your Ziniao / ZClaw bridge API key
ZCLAW_API_KEY=replace-with-your-api-key

# Optional compatibility alias if needed by surrounding tooling
ZINIAO_ZCLAW_API_KEY=
