{
  "project": {
    "id": "neosgo-marketing-suite",
    "name": "NEOSGO Marketing Suite",
    "business_goal": "grow qualified trade pipeline and website conversions for neosgo.com",
    "product_type": "b2b_lighting_ecommerce",
    "conversion_target": "trade_program_application",
    "priority_regions": [
      "RI",
      "MA",
      "CT",
      "NH",
      "ME",
      "VT",
      "NY",
      "CA",
      "TX",
      "FL"
    ],
    "risk_profile": "high"
  },
  "icp": {
    "account_types": [
      "showroom",
      "dealer",
      "distributor",
      "contractor",
      "builder",
      "electrician",
      "designer",
      "lighting"
    ],
    "personas": [
      "buyer",
      "founder",
      "operations_manager"
    ],
    "exclusions": [
      "student",
      "personal_blog"
    ]
  },
  "channels": {
    "priority": [
      "form",
      "linkedin",
      "email"
    ],
    "disallowed": [
      "sms",
      "email"
    ],
    "approval_required_for": [
      "pricing_discussion",
      "partner_offer",
      "high_value_accounts",
      "channel_partnerships",
      "trade_program_offer"
    ]
  },
  "prospect_data_engine": {
    "source_families": [
      "google_maps_places",
      "official_websites",
      "google_business_profile",
      "linkedin_company_pages",
      "trade_directories",
      "association_lists",
      "exhibitor_lists"
    ],
    "google_maps_capture": {
      "enabled": true,
      "keyword": "interior designer",
      "starting_region_group": "new_england",
      "coverage_scope": "new_england_only",
      "new_england_exhaustive": true,
      "max_queries_per_run": 4,
      "max_pages_per_query": 3,
      "page_size": 20,
      "email_enrichment_max_sites_per_run": 40,
      "field_mask": [
        "places.id",
        "places.displayName",
        "places.formattedAddress",
        "places.websiteUri",
        "places.googleMapsUri",
        "places.primaryType",
        "places.types",
        "nextPageToken"
      ],
      "region_plan": [
        {
          "group": "new_england",
          "state": "RI",
          "queries": [
            "interior designer in Rhode Island",
            "interior designer in Providence RI",
            "interior designer in Warwick RI",
            "interior designer in Newport RI"
          ]
        },
        {
          "group": "new_england",
          "state": "MA",
          "queries": [
            "interior designer in Massachusetts",
            "interior designer in Boston MA",
            "interior designer in Cambridge MA",
            "interior designer in Worcester MA",
            "interior designer in Newton MA"
          ]
        },
        {
          "group": "new_england",
          "state": "CT",
          "queries": [
            "interior designer in Connecticut",
            "interior designer in New Haven CT",
            "interior designer in Stamford CT",
            "interior designer in Hartford CT",
            "interior designer in Greenwich CT"
          ]
        },
        {
          "group": "new_england",
          "state": "NH",
          "queries": [
            "interior designer in New Hampshire",
            "interior designer in Manchester NH",
            "interior designer in Nashua NH",
            "interior designer in Portsmouth NH"
          ]
        },
        {
          "group": "new_england",
          "state": "ME",
          "queries": [
            "interior designer in Maine",
            "interior designer in Portland ME",
            "interior designer in Bangor ME",
            "interior designer in Kennebunk ME"
          ]
        },
        {
          "group": "new_england",
          "state": "VT",
          "queries": [
            "interior designer in Vermont",
            "interior designer in Burlington VT",
            "interior designer in Stowe VT",
            "interior designer in Montpelier VT"
          ]
        }
      ]
    },
    "score_weights": {
      "fit": 40,
      "intent": 30,
      "reachability": 20,
      "data_quality": 10
    },
    "min_score_for_strategy": 72
  },
  "marketing_strategy_engine": {
    "segmentation_axes": [
      "account_tier",
      "persona_type",
      "buying_context",
      "channel_readiness"
    ],
    "default_path_type": "direct_response",
    "require_human_review_for": [
      "tier_a_accounts",
      "legal_or_pricing_sensitive_motions",
      "trade_program_offer",
      "channel_partner_motion"
    ]
  },
  "outreach_feedback_engine": {
    "automation_mode": "controlled",
    "cooldown_rules": {
      "email_days": 7,
      "form_days": 14,
      "social_days": 4
    },
    "stop_conditions": [
      "unsubscribe",
      "do_not_contact",
      "hard_bounce",
      "complaint_risk",
      "invalid_contact"
    ],
    "reporting": {
      "daily": true,
      "weekly": true,
      "anomaly": true
    }
  }
}
