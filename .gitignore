# JinClaw repository policy:
# Track reproducible source assets only.
# Ignore runtime state, secrets, caches, large local environments, and personal memory.

# Personal and local-only context
/USER.md
/memory/
/.codex/
/.openclaw/
/.state/
/.logs/
/.learnings/

# Runtime outputs and transient workdirs
/output/
/data/
/reports/
/tmp/
/tools/openmoss/runtime/
/tools/openmoss/generated_capabilities/
/projects/**/data/

# Secrets and local environment files
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.local.json
!config.example.json
!*.example.json
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.mobileprovision
*.jks

# Python
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
**/.venv/
*-venv/
**/*-venv/
venv/
env/

# Node / JS
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs and local archives
*.log
*.tmp
*.bak
*.swp
*.swo
*.tgz
*.tar.gz
*.zip

# Databases and local binary state
*.db
*.sqlite
*.sqlite3
*.wal
*.journal
.python-version
