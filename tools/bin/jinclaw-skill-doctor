#!/usr/bin/env python3
import json
import sys
from pathlib import Path

ROOT = Path('/Users/mac_claw/.openclaw/workspace')
SKILLS = ROOT / 'skills'
errors = []
checked = 0
legacy_seen = 0

if not SKILLS.exists():
    print('No skills directory found.')
    sys.exit(0)

for skill_dir in sorted([p for p in SKILLS.iterdir() if p.is_dir()]):
    skill_md = skill_dir / 'SKILL.md'
    tmpl = skill_dir / 'SKILL.md.tmpl'
    manifest = skill_dir / 'skill-factory-manifest.json'
    if not skill_md.exists():
        continue

    # Legacy/non-factory skills are allowed to coexist.
    # Enforce full lifecycle/template requirements only for factory-managed skills.
    if not manifest.exists():
        legacy_seen += 1
        continue

    checked += 1
    text = skill_md.read_text()
    if not tmpl.exists():
        errors.append(f'{skill_dir.name}: missing SKILL.md.tmpl')
    if not text.startswith('---\nname: '):
        errors.append(f'{skill_dir.name}: invalid or missing YAML frontmatter start')
    if '\n## Execution Lifecycle\n' not in text:
        errors.append(f'{skill_dir.name}: missing execution lifecycle section')
    for stage in ['1. think', '2. plan', '3. build', '4. review', '5. test', '6. ship', '7. reflect']:
        if stage not in text:
            errors.append(f'{skill_dir.name}: missing lifecycle stage {stage}')
    try:
        data = json.loads(manifest.read_text())
        if data.get('skill_name') != skill_dir.name:
            errors.append(f'{skill_dir.name}: manifest skill_name mismatch')
    except Exception as exc:
        errors.append(f'{skill_dir.name}: manifest unreadable: {exc}')

if errors:
    print('jinclaw-skill-doctor FAILED')
    for err in errors:
        print(f'- {err}')
    sys.exit(1)

print(f'jinclaw-skill-doctor OK ({checked} factory skills checked, {legacy_seen} legacy skills skipped)')
