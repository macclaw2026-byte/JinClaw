#!/bin/zsh

set -euo pipefail

ROOT="/Users/mac_claw/.openclaw/workspace"

print_status() {
  local label="$1"
  local state="$2"
  local detail="$3"
  printf '%-24s %-10s %s\n' "$label" "$state" "$detail"
}

echo "JinClaw Integration Status"
echo

print_status "chat-ingress" "ACTIVE" "OpenClaw native channels.telegram -> gateway"
print_status "bridge-runtime" "RETIRED" "$ROOT/tools/openmoss/bridge"
print_status "autonomy-runtime" "ACTIVE" "$ROOT/tools/openmoss/autonomy/runtime_service.py"
print_status "control-center" "ACTIVE" "$ROOT/tools/openmoss/control_center"
print_status "voice-runtime" "OPTIONAL" "$ROOT/tools/openmoss/voice"

echo
echo "Current policy:"
echo "  - IMClaw/OpenMOSS bridge has been retired from the runtime path."
echo "  - New chat channels should be added through 'openclaw configure'."
