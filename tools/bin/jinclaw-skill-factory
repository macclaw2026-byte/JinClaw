#!/usr/bin/env python3
import argparse
import json
import os
import re
import sys
from pathlib import Path

ROOT = Path('/Users/mac_claw/.openclaw/workspace')
OUT_BASE = ROOT / 'skills'
TEMPLATE_DIRNAME = 'templates'
REFERENCE_DIRNAME = 'references'
SCRIPT_DIRNAME = 'scripts'
ASSET_DIRNAME = 'assets'

QUESTIONS = [
    ('skill_name', 'Skill name in kebab-case'),
    ('description', 'One-sentence description including when the skill should be used'),
    ('goal', 'Core job this skill should accomplish'),
    ('triggers', 'What user requests or situations should trigger this skill?'),
    ('inputs', 'Key inputs expected by the skill'),
    ('outputs', 'Key outputs or artifacts expected from the skill'),
    ('workflow', 'Step-by-step workflow the skill should follow'),
    ('guardrails', 'Safety, quality, or boundary rules'),
    ('references_needed', 'Reference files needed (comma-separated, optional)'),
    ('scripts_needed', 'Scripts needed (comma-separated, optional)'),
    ('assets_needed', 'Assets needed (comma-separated, optional)'),
]

def slugify(value: str) -> str:
    value = value.strip().lower()
    value = re.sub(r'[^a-z0-9]+', '-', value)
    value = re.sub(r'-+', '-', value).strip('-')
    return value[:63]


def parse_csv(value: str):
    return [item.strip() for item in value.split(',') if item.strip()]


def ensure_dir(path: Path):
    path.mkdir(parents=True, exist_ok=True)


def questionnaire_mode(args):
    data = {}
    print('JinClaw Skill Factory Questionnaire')
    print('Answer briefly but concretely. Leave optional lists blank if not needed.\n')
    for key, prompt in QUESTIONS:
        data[key] = input(f'{prompt}: ').strip()
    if not data['skill_name']:
        raise SystemExit('skill_name is required')
    data['skill_name'] = slugify(data['skill_name'])
    return data


def load_answers(path: Path):
    raw = path.read_text()
    if path.suffix.lower() == '.json':
        data = json.loads(raw)
    else:
        data = {}
        for line in raw.splitlines():
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            if ':' not in line:
                continue
            k, v = line.split(':', 1)
            data[k.strip()] = v.strip()
    data['skill_name'] = slugify(data.get('skill_name', ''))
    if not data['skill_name']:
        raise SystemExit('answers file must include skill_name')
    return data


def build_skill_tmpl(data: dict) -> str:
    refs = parse_csv(data.get('references_needed', ''))
    scripts = parse_csv(data.get('scripts_needed', ''))
    lines = [
        '---',
        f"name: {data['skill_name']}",
        f"description: {data.get('description', '').strip()}",
        '---',
        '',
        f"# {data['skill_name']}",
        '',
        '## Mission',
        data.get('goal', '').strip() or 'TODO: define mission.',
        '',
        '## Trigger Guidance',
        data.get('triggers', '').strip() or 'TODO: define triggers.',
        '',
        '## Inputs',
        data.get('inputs', '').strip() or 'TODO: define inputs.',
        '',
        '## Outputs',
        data.get('outputs', '').strip() or 'TODO: define outputs.',
        '',
        '## Workflow',
        data.get('workflow', '').strip() or 'TODO: define workflow.',
        '',
        '## Guardrails',
        data.get('guardrails', '').strip() or 'TODO: define guardrails.',
        '',
    ]
    if refs:
        lines.extend(['## References', 'Read these reference files when needed:'])
        lines.extend([f'- references/{name}.md' for name in refs])
        lines.append('')
    if scripts:
        lines.extend(['## Scripts', 'Use these scripts when deterministic execution is preferable:'])
        lines.extend([f'- scripts/{name}' for name in scripts])
        lines.append('')
    lines.extend([
        '## Execution Lifecycle',
        'Follow this full lifecycle unless explicitly scoped out:',
        '1. think',
        '2. plan',
        '3. build',
        '4. review',
        '5. test',
        '6. ship',
        '7. reflect',
        '',
        '## Completion Contract',
        '- report stage completion status',
        '- summarize artifacts created or modified',
        '- cite evidence and validation',
        '- note unresolved uncertainty or risks',
        '- recommend next step',
        ''
    ])
    return '\n'.join(lines)


def render_skill_md(tmpl_text: str) -> str:
    # First implementation: template is already valid markdown.
    # Keep a dedicated render step so future automation can expand placeholders.
    return tmpl_text


def scaffold(data: dict, dry_run: bool = False):
    skill_name = data['skill_name']
    skill_dir = OUT_BASE / skill_name
    tmpl_path = skill_dir / 'SKILL.md.tmpl'
    skill_md_path = skill_dir / 'SKILL.md'
    refs = parse_csv(data.get('references_needed', ''))
    scripts = parse_csv(data.get('scripts_needed', ''))
    assets = parse_csv(data.get('assets_needed', ''))
    tmpl = build_skill_tmpl(data)
    skill_md = render_skill_md(tmpl)

    if dry_run:
        print(json.dumps({
            'skill_dir': str(skill_dir),
            'files': [str(tmpl_path), str(skill_md_path)],
            'references': refs,
            'scripts': scripts,
            'assets': assets,
        }, indent=2))
        return

    ensure_dir(skill_dir)
    tmpl_path.write_text(tmpl)
    skill_md_path.write_text(skill_md)

    if refs:
        ensure_dir(skill_dir / REFERENCE_DIRNAME)
        for name in refs:
            p = skill_dir / REFERENCE_DIRNAME / f'{name}.md'
            if not p.exists():
                p.write_text(f'# {name}\n\nTODO: add reference content.\n')

    if scripts:
        ensure_dir(skill_dir / SCRIPT_DIRNAME)
        for name in scripts:
            p = skill_dir / SCRIPT_DIRNAME / name
            if not p.exists():
                p.write_text('#!/usr/bin/env bash\nset -euo pipefail\n\necho "TODO: implement script"\n')
                os.chmod(p, 0o755)

    if assets:
        ensure_dir(skill_dir / ASSET_DIRNAME)
        for name in assets:
            p = skill_dir / ASSET_DIRNAME / name
            if not p.exists():
                p.write_text('TODO: add asset placeholder\n')

    manifest = {
        'skill_name': skill_name,
        'generated_by': 'jinclaw-skill-factory',
        'generated_files': [
            'SKILL.md.tmpl',
            'SKILL.md',
        ],
        'references': refs,
        'scripts': scripts,
        'assets': assets,
    }
    (skill_dir / 'skill-factory-manifest.json').write_text(json.dumps(manifest, indent=2))
    print(f'Generated skill scaffold at {skill_dir}')


def main():
    parser = argparse.ArgumentParser(description='Generate JinClaw skill scaffolds from a questionnaire or answers file.')
    parser.add_argument('--answers', help='Path to JSON or simple key:value answers file')
    parser.add_argument('--dry-run', action='store_true')
    args = parser.parse_args()

    if args.answers:
        data = load_answers(Path(args.answers))
    else:
        data = questionnaire_mode(args)
    scaffold(data, dry_run=args.dry_run)

if __name__ == '__main__':
    main()
